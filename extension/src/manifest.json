{
  "manifest_version": 3,
  "name": "EnhancedBlocker",
  "version": "0.1.0",
  "description": "Context-aware website blocker + time tracker (M1: tracking + Tier-0 blocker).",
  "key": "",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "EnhancedBlocker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["webNavigation", "storage", "tabs", "scripting"],
  "host_permissions": ["http://127.0.0.1/*"],
  "web_accessible_resources": [
    {
      "resources": ["block.html", "main.js", "styles.css"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
